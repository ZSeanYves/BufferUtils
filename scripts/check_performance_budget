#!/usr/bin/env bash
set -euo pipefail

csv=${1:-.tmp/bufferutils-bench/results.csv}
baseline=${2:-}
if [[ ! -f "$csv" ]]; then
  printf 'benchmark CSV not found: %s\n' "$csv" >&2
  exit 1
fi

awk -F, '
NR == 1 {
  for (i = 1; i <= NF; i++) column[$i] = i
  required["median_us"] = 1
  required["p95_us"] = 1
  required["copied_bytes"] = 1
  required["allocations"] = 1
  required["underlying_calls"] = 1
  required["syscalls"] = 1
  for (name in required) if (!(name in column)) missing = missing name " "
  if (missing != "") { print "missing benchmark columns: " missing > "/dev/stderr"; exit 1 }
  next
}
{
  name = $(column["name"])
  size = $(column["size"])
  median = $(column["median_us"])
  p95 = $(column["p95_us"])
  if (median <= 0 || p95 < median) {
    print "invalid benchmark timing: " name " " size > "/dev/stderr"
    exit 1
  }
  if ($(column["copied_bytes"]) < 0) { print "negative copied_bytes" > "/dev/stderr"; exit 1 }
  if ($(column["allocations"]) < 0 || $(column["underlying_calls"]) < 0 || $(column["syscalls"]) < 0) {
    print "negative benchmark counters" > "/dev/stderr"; exit 1
  }
  seen[name] = 1
  timings[name SUBSEP size] = median
  if (name == "buffer_shared_split_freeze" &&
      $(column["copied_bytes"]) != 0) {
    print "split/freeze copied payload bytes" > "/dev/stderr"
    exit 1
  }
}
END {
  required_case["buffer_shared_split_freeze"] = 1
  required_case["buffer_cow_mutation"] = 1
  required_case["sync_raw_read_to_end"] = 1
  required_case["sync_bufreader_read_to_end"] = 1
  required_case["sync_raw_write_all"] = 1
  required_case["sync_bufwriter_write_flush"] = 1
  required_case["native_file_write_flush"] = 1
  required_case["native_file_read"] = 1
  required_case["native_mmap_read_scan"] = 1
  required_case["sync_short_write_1B"] = 1
  required_case["sync_short_write_16B"] = 1
  required_case["sync_small_write_1B"] = 1
  required_case["sync_small_write_32B"] = 1
  required_case["sync_small_write_256B"] = 1
  required_case["sync_vectored_write"] = 1
  for (name in required_case) if (!(name in seen)) {
    print "missing benchmark case: " name > "/dev/stderr"
    exit 1
  }
  raw_read = timings["sync_raw_read_to_end" SUBSEP "1MB"]
  buffered_read = timings["sync_bufreader_read_to_end" SUBSEP "1MB"]
  raw_write = timings["sync_raw_write_all" SUBSEP "1MB"]
  buffered_write = timings["sync_bufwriter_write_flush" SUBSEP "1MB"]
  if (buffered_read > raw_read * 1.10) {
    print "1MB BufReader bypass is more than 10% slower than raw read" > "/dev/stderr"
    exit 1
  }
  if (buffered_write > raw_write * 1.10) {
    print "1MB BufWriter bypass is more than 10% slower than raw write" > "/dev/stderr"
    exit 1
  }
  print "performance budget input is structurally valid"
}
' "$csv"

if [[ -n "$baseline" ]]; then
  [[ -f "$baseline" ]] || {
    printf 'benchmark baseline not found: %s\n' "$baseline" >&2
    exit 1
  }
  awk -F, '
  NR == 1 {
    for (i = 1; i <= NF; i++) column[$i] = i
    next
  }
  NR == FNR {
    key = $(column["name"]) SUBSEP $(column["size"])
    base[key] = $(column["median_us"])
    next
  }
  FNR == 1 { next }
  {
    key = $(column["name"]) SUBSEP $(column["size"])
    if (key in base && $(column["median_us"]) > base[key] * 1.10) {
      print "median regression exceeds 10%: " key > "/dev/stderr"
      failed = 1
    }
  }
  END { exit failed }
  ' "$baseline" "$csv"
fi
